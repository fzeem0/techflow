#!/usr/bin/env bash

set -euo pipefail

TECHFLOW_HOME=${TECHFLOW_HOME:-}
DISK_THRESHOLD=${TECHFLOW_DISK_THRESHOLD:-90}
ANY_FAIL=0

if [[ -t 1 && -z ${NO_COLOR:-} ]]; then
    GREEN=$'\033[0;32m'
    RED=$'\033[0;31m'
    RESET=$'\033[0m'
else
    GREEN=''
    RED=''
    RESET=''
fi

check_status() {
    local name=$1
    local status=$2
    if ((status == 0)); then
        printf '%s: %sPASS%s\n' "$name" "$GREEN" "$RESET"
    else
        printf '%s: %sFAIL%s\n' "$name" "$RED" "$RESET"
        ANY_FAIL=1
    fi
}

if [[ -z "$TECHFLOW_HOME" || ! -f "$TECHFLOW_HOME/.techflow-workspace" ]]; then
    echo "TECHFLOW_HOME must point to an initialized training workspace" >&2
    exit 2
fi

if [[ ! "$DISK_THRESHOLD" =~ ^[0-9]+$ ]] || ((DISK_THRESHOLD < 1 || DISK_THRESHOLD > 100)); then
    echo "TECHFLOW_DISK_THRESHOLD must be an integer from 1 to 100" >&2
    exit 2
fi

ROOT_USAGE=$(df -P "$TECHFLOW_HOME" | awk 'NR==2 {gsub(/%/, "", $5); print $5}')
if [[ "$ROOT_USAGE" =~ ^[0-9]+$ ]] && ((ROOT_USAGE < DISK_THRESHOLD)); then
    check_status "Workspace disk usage below ${DISK_THRESHOLD}%" 0
else
    check_status "Workspace disk usage below ${DISK_THRESHOLD}%" 1
fi

if command -v python3 > /dev/null 2>&1; then
    check_status "Python 3 available" 0
else
    check_status "Python 3 available" 1
fi

if [[ -s "$TECHFLOW_HOME/logs/syslog.log" ]]; then
    check_status "Training syslog available" 0
else
    check_status "Training syslog available" 1
fi

if [[ -r "$TECHFLOW_HOME/config/app.conf" ]]; then
    check_status "Application config readable" 0
else
    check_status "Application config readable" 1
fi

exit "$ANY_FAIL"
