#!/usr/bin/env bash

set -euo pipefail

TECHFLOW_HOME=${TECHFLOW_HOME:-}
PORT=${TECHFLOW_PORT:-8888}

[[ -n "$TECHFLOW_HOME" && -f "$TECHFLOW_HOME/.techflow-workspace" ]] || {
    echo "TECHFLOW_HOME must point to an initialized training workspace" >&2
    exit 2
}

PID_FILE="$TECHFLOW_HOME/app/server.pid"
LOG_FILE="$TECHFLOW_HOME/logs/app.log"
SERVER="$TECHFLOW_HOME/app/server.py"

if [[ -f "$PID_FILE" ]]; then
    old_pid=$(<"$PID_FILE")
    if [[ "$old_pid" =~ ^[0-9]+$ ]] && kill -0 "$old_pid" 2>/dev/null; then
        echo "TechFlow app is already running with PID $old_pid"
        exit 0
    fi
    rm -f "$PID_FILE"
fi

nohup python3 "$SERVER" --host 0.0.0.0 --port "$PORT" >> "$LOG_FILE" 2>&1 &
pid=$!
printf '%s\n' "$pid" > "$PID_FILE"

for _ in $(seq 1 30); do
    if curl --fail --silent "http://127.0.0.1:$PORT/health" >/dev/null; then
        echo "TechFlow app started with PID $pid on port $PORT"
        exit 0
    fi
    if ! kill -0 "$pid" 2>/dev/null; then
        echo "TechFlow app failed to start; inspect $LOG_FILE" >&2
        rm -f "$PID_FILE"
        exit 1
    fi
    sleep 0.1
done

kill "$pid" 2>/dev/null || true
rm -f "$PID_FILE"
echo "TechFlow app did not become healthy; inspect $LOG_FILE" >&2
exit 1
