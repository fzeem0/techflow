#!/usr/bin/env bash

set -euo pipefail

PROJECT_ROOT=${TECHFLOW_PROJECT_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}
TECHFLOW_HOME=${TECHFLOW_HOME:-}
MISSION_DIR="$PROJECT_ROOT/missions"
HINT_DIR="$PROJECT_ROOT/hints"

readonly NAMES=(
    "Server Recon — Know Your Machine"
    "Filesystem Disaster Recovery"
    "Log Investigation — Find the Incident"
    "Text Processing Gauntlet"
    "Process Crisis Management"
    "Network Diagnosis"
    "Bash Scripting — Automate Everything"
    "Git Operations Workflow"
    "System Administration"
)

usage() {
    cat << 'EOF'
Usage: techflow [menu|status|check]
       techflow mission <1-9>
       techflow hint <1-9>
       techflow verify <1-9>
       techflow done <1-9>

Commands:
  menu         show all missions
  status       show completion percentage
  mission N    display mission N
  hint N       display focused hints for mission N
  verify N     validate and mark mission N complete
  done N       alias for verify; completion cannot bypass validation
  check        check the training workspace health
EOF
}

ensure_workspace() {
    [[ -n "$TECHFLOW_HOME" ]] || {
        echo "TECHFLOW_HOME is not set; use the Docker launcher or set an absolute workspace path" >&2
        exit 2
    }
    if [[ ! -f "$TECHFLOW_HOME/.techflow-workspace" ]]; then
        "$PROJECT_ROOT/scripts/init_workspace.sh" --workspace "$TECHFLOW_HOME"
    fi
    PROGRESS_FILE="$TECHFLOW_HOME/.progress"
    [[ -f "$PROGRESS_FILE" ]] || touch "$PROGRESS_FILE"
}

validate_mission() {
    [[ "${1:-}" =~ ^[1-9]$ ]] || {
        echo "Mission must be a number from 1 to 9" >&2
        exit 2
    }
}

completed() {
    grep -qx "$1" "$PROGRESS_FILE" 2> /dev/null
}

next_mission() {
    local mission
    for mission in {1..9}; do
        if ! completed "$mission"; then
            echo "$mission"
            return
        fi
    done
    echo 10
}

mark_done() {
    local mission=$1 temp_file
    completed "$mission" && return

    exec 9> "$PROGRESS_FILE.lock"
    command -v flock > /dev/null 2>&1 && flock 9
    temp_file=$(mktemp "${PROGRESS_FILE}.tmp.XXXXXX")
    trap 'rm -f "${temp_file:-}"' RETURN
    {
        cat "$PROGRESS_FILE"
        printf '%s\n' "$mission"
    } |
        awk '/^[1-9]$/' |
        sort -n -u > "$temp_file"
    mv "$temp_file" "$PROGRESS_FILE"
    trap - RETURN
}

menu() {
    local mission marker next
    next=$(next_mission)
    printf '\nTechFlow DevOps Training\n\n'
    for mission in {1..9}; do
        if completed "$mission"; then
            marker='[x]'
        elif ((mission == next)); then
            marker='[>]'
        else
            marker='[ ]'
        fi
        printf '  %s M%d: %s\n' "$marker" "$mission" "${NAMES[$((mission - 1))]}"
    done
    printf '\nUse: techflow mission <N> | hint <N> | verify <N>\n\n'
}

status() {
    local count
    count=$(awk '/^[1-9]$/' "$PROGRESS_FILE" | sort -u | wc -l)
    printf 'Completed: %d/9 (%d%%)\n' "$count" "$((count * 100 / 9))"
    menu
}

show_mission() {
    validate_mission "${1:-}"
    python3 "$PROJECT_ROOT/scripts/render_markdown.py" \
        "$MISSION_DIR/$(printf '%02d' "$1").md"
}

show_hint() {
    local mission=${1:-}
    validate_mission "$mission"
    python3 "$PROJECT_ROOT/scripts/render_markdown.py" \
        --title "Hint for Mission $mission — ${NAMES[$((mission - 1))]}" \
        "$HINT_DIR/$(printf '%02d' "$mission").txt"
}

verify_mission() {
    validate_mission "${1:-}"
    "$PROJECT_ROOT/scripts/verify_mission.sh" "$1"
    mark_done "$1"
    echo "Progress saved."
}

ensure_workspace
case "${1:-menu}" in
    menu) menu ;;
    status) status ;;
    mission) show_mission "${2:-}" ;;
    hint) show_hint "${2:-}" ;;
    verify | done) verify_mission "${2:-}" ;;
    check) "$PROJECT_ROOT/scripts/check_health" ;;
    -h | --help | help) usage ;;
    *)
        usage >&2
        exit 2
        ;;
esac
